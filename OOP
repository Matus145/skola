class Trieda():

    def __init__(self, index_triedy , triedny_ucitel, ucebna) -> None:
        self._index = index_triedy
        self._triedny_ucitel = triedny_ucitel
        self._ucebna = ucebna
        self._ziaci = []
    #Property - get
    def get_index(self) -> str:
        return self._index 
    
    def get_triedny(self) -> str:
        return self._triedny_ucitel
    
    def get_ucebna(self) -> int:
        return self._ucebna
    
    def get_triedny_ucitel(self):
        ucitel = self._triedny_ucitel.get_meno() + " " + self._triedny_ucitel.get_priezvisko()
        return ucitel
    #Metoda
    def get_ziaci(self) -> str:
        ziaci = []
        for item in self._ziaci:
            ziaci.append(item.get_meno() + " " + item.get_priezvisko())
        return ziaci
    #Metoda
    def add_student(self, new_ziak):
        self._ziaci.append(new_ziak)
    #Property - set
    def set_index(self, new_index):
        self._index = new_index

    def set_triedny(self, new_triedny_ucitel):
        self._triedny_ucitel = new_triedny_ucitel

    def set_ucebna(self, new_ucebna):
        self._ucebna = new_ucebna
#Objekty
    def get_data(self):
            return f"\
            \r Trieda {self.get_index()}. \n \
            \r Triedny ucitel: {self.get_triedny_ucitel()}. \n \
            \r Ucebna: {self.get_ucebna()}. \n \
            \r Ziaci: \n {self.get_ziaci()}"

