                 minibar: bool, klima: bool, vana: bool):
        
        self.meno = meno
        self.cena = cena
        self.velkost = velkost_m2
        self.postele = postele
        self.minibar = minibar
        self.klima = klima
        self.vana = vana

        def get_info(self) -> str:
            doplnky = []
            if self.vaňa:
                doplnky.append("Vaňa")
