
from typing import override

class GameCalc:

    @staticmethod
    def count_critical_hit(base_damage, chance):
        if chance > 70:
            return base_damage * 2
        return base_damage
        

class Hero:
    
    def __init__(self, name, health, attack):
        self.name = name #verejny/public
        self.__health = health #private __
        self._attack = attack #protected _

    @property
    def health(self):
        return self.__health
    
    @health.setter
    def health(self, value):
        if value < 0:
            self.__health = 0
        else:
            self.__health = value

    def attack(self):
        #Basic útok
        return f"{self.name} útočí s pośkodením {self._attack}"

class Warrior(Hero):
    
    def __init__(self, name, health, attack, armor):
        super().__init__(name, health, attack) #zavolame konstruktor triedy hero
        self.armor = armor

    @override #polymorfizmus
    def attack(self):
        final_damage = GameCalc.count_critical_hit(self._attack, chance = 80)
        return f"Warrior {self.name} seká sekerou za {final_damage} bodov! (Brnenie: {self.armor})"

class Wizard(Hero):
    
    def __init__(self, name, health, attack, mana):
        super().__init__(name, health, attack)
        self.mana = mana

    @override
    def attack(self):
        if self.mana > 10:
            self.mana -= 10
            return f"Wizard {self.name} zoslal ohnivú guľu! (Zostavujúca mana {self.mana})"
        return f"Wizard {self.name}, nemá dosť many, útoči palicou za {self.attack}!"
    
    def cast_spell(self, target, area = False): 
        if area:
            return f"Wizard {self.name} zoslal plošné kúzlo na celú skupinu okolo {target}"
        return f"Wizard {self.name} zoslal kúzlo priamo na cieľ: {target}"
    
#polymorfizmus
def battle_talk(list_of_heroes):
    print("\n--- Boj začína! (Polymorfizmus) ---")
    for hero in list_of_heroes:
        print(hero.attack())


if __name__ == "__main__":
    #zapúzdrenie - encapsulation
    gerald = Warrior("Gerald", health=150, attack=25, armor=50)
    gandalf = Wizard ("Gandalf", health=80, attack=5, mana=30)

    # pouzitie encapsulation a propety
    gerald.health -= 20 #setter zachiti zapornu hodnotu a nastavi min. hodnotu teda 0
    print(f"Geraldovo zdravie po zranení: {gerald.health}") #uz pracujem s propety nie s atributom

    gerald.health = 100 #bojovnik je vylieceny, cez property setter
    print(f"Geraldovo zdravie po vylieceny: {gerald.health}")


    #pretazenie (overload)
    print(gandalf.cast_spell("Skret"))
    print(gandalf.cast_spell("Skret", area=True))

    #vytvorime skupinu
    group = [
        gerald,
        gandalf,
        Hero("Dedko večerníček", health=20, attack=2)
    ]

    battle_talk(group)
